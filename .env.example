# ============================================================
# ContentOS — PEMedia Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git
# ============================================================

# ── PHASE 1 (Required for basic operation) ─────────────────

# Anthropic Claude API — console.anthropic.com
ANTHROPIC_API_KEY=

# Supabase — supabase.com > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Pexels (free stock footage) — pexels.com/api
PEXELS_API_KEY=

# App URL (used by QStash to know where to deliver messages)
# Local: http://localhost:3000  |  Production: https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── PHASE 2 (YouTube + Automation) ─────────────────────────

# Upstash QStash (job queue + cron schedules — replaces BullMQ) — upstash.com > QStash
# Free tier: 500 messages/day. Get all three keys from the QStash console.
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# Admin secret protecting /api/admin/schedule (register/inspect/remove the daily
# CEO cron). Generate with: openssl rand -base64 32
CRON_ADMIN_SECRET=

# Google OAuth — console.cloud.google.com > Credentials
# Enable: YouTube Data API v3, YouTube Analytics API, Google+ API
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# YouTube API Key (for public data queries)
YOUTUBE_API_KEY=

# ElevenLabs (voice generation) — elevenlabs.io
# Free: 10K chars/mo. Starter: $5/mo. Add after first $50 affiliate revenue.
ELEVENLABS_API_KEY=
ELEVENLABS_DEFAULT_VOICE_ID=

# ── Local rendering / output ───────────────────────────────
# Where finished videos + thumbnails are written (absolute path — NOT the OS temp dir,
# so renders persist). Default: ~/ContentOS/output. Point at any drive to move the
# library, e.g. D:\PEMedia\renders  (Windows) or /mnt/storage/pemedia (Linux).
CONTENT_OUTPUT_DIR=
# ffmpeg tuning (optional): render framerate and x264 preset. Defaults: 15 / veryfast.
FFMPEG_FPS=
FFMPEG_PRESET=
# Max characters per ElevenLabs TTS request (long narration is auto-chunked). Default 9000.
ELEVENLABS_MAX_TTS_CHARS=
# Royalty-free music library — drop CC0 tracks here (optionally in <niche> subfolders).
# Mixed low under the narration. Empty/missing = no music. Default: ~/ContentOS/music.
# Free sources: Pixabay Music, YouTube Audio Library, Incompetech (check each licence).
CONTENT_MUSIC_DIR=

# Upstash Redis — reserved for path-B BullMQ worker (future persistent host only)
# Not needed while running on Vercel with QStash.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Reddit API (trend signals) — reddit.com/prefs/apps > script app
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=contentOS/1.0

# SerpAPI (Google Trends) — serpapi.com > Free tier: 100 searches/mo
SERPAPI_API_KEY=

# Pixabay (additional free stock) — pixabay.com/api/docs
PIXABAY_API_KEY=

# ── PHASE 3 (Add when funded by revenue) ──────────────────

# Muapi.ai (OpenGenAI video generation) — muapi.ai
# Add when monthly revenue covers the cost
MUAPI_API_KEY=

# Creatomate (video assembly API) — creatomate.com
# Free: 30 renders/mo. Paid: $29/mo. Add when production agent is active.
CREATOMATE_API_KEY=
